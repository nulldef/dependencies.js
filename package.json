{
  "name": "dependencies.js",
  "version": "1.2.0",
  "description": "Dependencies.js is a JavaScript library that provides a simple and efficient way to manage dependencies in your projects. It allows you to define and resolve dependencies between modules, making it easier to organize and maintain your codebase.",
  "repository": {
    "url": "https://github.com/nulldef/dependencies.js",
    "type": "git"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "scripts": {
    "lib:build": "tsc --project tsconfig.build.json",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text --reporter=junit --reporter-outfile=tests.junit.xml",
    "types:check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cleanup": "rm -rf *.js *.d.ts *.map",
    "prepublish": "npm run cleanup && npm run build"
  },
  "keywords": [],
  "author": "Aleksei Bespalov <nulldefiner@gmail.com>",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/bun": "^1.3.13",
    "@types/mocha": "^10.0.10",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  }
}
